#include<iostream>
using namespace std;

class Fibonacci {

public:

    int fib(int n) {

        if(n == 0) {
            return 0;
        }

        else if(n == 1) {
            return 1;
        }

        else {
            return fib(n - 1) + fib(n - 2);
        }
    }
};

int main() {

    int n;

    cout << "Enter number of terms: ";
    cin >> n;

    Fibonacci obj;

    cout << "Fibonacci Series:\n";

    for(int i = 0; i < n; i++) {
        cout << obj.fib(i) << " ";
    }

    return 0;
}
