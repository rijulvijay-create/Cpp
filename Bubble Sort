// Bubble Sort: Sort array in ascending order
// Time: O(n²) always | Space: O(1)

#include <iostream>
using namespace std;

void bubbleSort(int arr[], int n) {
    for (int i = 0; i < n - 1; i++) {          // n-1 passes
        for (int j = 0; j < n - i - 1; j++) {   // Skip sorted end
            if (arr[j] > arr[j + 1]) {
                swap(arr[j], arr[j + 1]);          // Swap neighbors
            }
        }
    }
}

void printArray(int arr[], int n) {
    for (int i = 0; i < n; i++)
        cout << arr[i] << " ";
    cout << endl;
}

int main() {
    int arr[] = {64, 34, 25, 12, 22, 11};
    int n = sizeof(arr) / sizeof(arr[0]);

    bubbleSort(arr, n);
    printArray(arr, n);
    // Output: 11 12 22 25 34 64
    return 0;
}
