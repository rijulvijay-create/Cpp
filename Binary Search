// Iterative Binary Search
// Time: O(log n) | Space: O(1)  ← best version for memory

#include <iostream>
using namespace std;

int binarySearch(int arr[], int n, int target) {
    int left = 0;
    int right = n - 1;

    while (left <= right) {
        // IMPORTANT: Use this formula to avoid integer overflow!
        int mid = left + (right - left) / 2;

        if (arr[mid] == target)
            return mid;            // Found!

        else if (arr[mid] < target)
            left = mid + 1;         // Target in RIGHT half

        else
            right = mid - 1;        // Target in LEFT half
    }

    return -1;                     // Not found
}

int main() {
    int arr[] = {1, 3, 5, 7, 9, 11, 13}; // Must be sorted!
    int n = sizeof(arr) / sizeof(arr[0]);

    cout << binarySearch(arr, n, 9) << endl;   // Output: 4
    cout << binarySearch(arr, n, 1) << endl;   // Output: 0
    cout << binarySearch(arr, n, 99) << endl;  // Output: -1
    return 0;
}
