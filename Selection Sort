// Selection Sort: Find minimum, place at correct position
// Time: O(n²) always | Space: O(1) | Swaps: O(n) — only n-1 swaps total!

#include <iostream>
using namespace std;

void selectionSort(int arr[], int n) {
    for (int i = 0; i < n - 1; i++) {
        int minIdx = i;             // Assume current position is minimum

        for (int j = i + 1; j < n; j++) {
            if (arr[j] < arr[minIdx]) {
                minIdx = j;          // Found a new minimum
            }
        }

        // Place minimum at correct position (only if needed)
        if (minIdx != i)
            swap(arr[minIdx], arr[i]);
    }
}

int main() {
    int arr[] = {64, 25, 12, 22, 11};
    int n = sizeof(arr) / sizeof(arr[0]);
    selectionSort(arr, n);
    // Output: 11 12 22 25 64
    return 0;
}
